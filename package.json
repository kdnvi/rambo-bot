{
  "name": "rambo-bot",
  "version": "0.1.0",
  "description": "Our discord bot, its name is Rambo",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "deploy:commands": "node --env-file=.env deploy-commands.js",
    "dev": "node --env-file=.env index.js",
    "docker:build": "docker build -t ghcr.io/kdnvi/rambo-bot:latest .",
    "docker:push": "docker push ghcr.io/kdnvi/rambo-bot:latest",
    "docker:deploy": "npm run docker:build && npm run docker:push",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/utils/*.test.js"
    ],
    "coverageProvider": "v8",
    "collectCoverageFrom": [
      "utils/*.js",
      "!utils/*.test.js",
      "!utils/firebase.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kdnvi/rambo-bot.git"
  },
  "keywords": [
    "discord-bot"
  ],
  "author": "Khoa Nguyen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kdnvi/rambo-bot/issues"
  },
  "homepage": "https://github.com/kdnvi/rambo-bot",
  "dependencies": {
    "cron": "^4.3.3",
    "discord.js": "^14.22.1",
    "firebase-admin": "^13.5.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "eslint": "^9.35.0",
    "jest": "^30.3.0"
  }
}
